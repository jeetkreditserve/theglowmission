# Core
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,theglowmission.local
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://theglowmission.com
NEXT_PUBLIC_API_BASE_URL=http://localhost/api/v1
INTERNAL_API_BASE_URL=http://backend:8000/api/v1

# Database
POSTGRES_DB=theglowmission
POSTGRES_USER=theglowmission
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://theglowmission:change-me@postgres:5432/theglowmission

# Initial CMS admin
ADMIN_EMAIL=admin@theglowmission.local
ADMIN_PASSWORD=change-me-now

# Required real S3 media storage. Do not use LocalStack for this project.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-south-1
AWS_MEDIA_LOCATION=media
AWS_SEED_ASSET_LOCATION=seed-assets
AWS_PRESIGNED_URL_EXPIRE_SECONDS=900
AWS_S3_SIGNATURE_VERSION=s3v4
AWS_S3_CUSTOM_DOMAIN=
# Optional real AWS-compatible production endpoint only. Leave blank for AWS S3.
AWS_S3_ENDPOINT_URL=
